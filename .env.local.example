# ─── Resend Email API ────────────────────────────────────────────────────────
# Service: https://resend.com  (free — 3 000 emails/month, no credit card)
# Steps:  1. Sign up at resend.com
#         2. Go to API Keys → Create API Key
#         3. Paste the key (starts with re_...) below
RESEND_API_KEY=re_paste_your_key_here

# The email address that receives quote notifications (your inbox)
ADMIN_EMAIL=fizzaniaz.17@gmail.com

# "From" display — must be a verified domain on Resend OR use onboarding@resend.dev for testing
FROM_NAME=Evoke Hub
FROM_EMAIL=onboarding@resend.dev

# ─── Admin Dashboard ─────────────────────────────────────────────────────────
# Password for the /admin dashboard — change this to something strong!
ADMIN_PASSWORD=change-me-strong-password

# Your production site URL (used for admin email links)
SITE_URL=https://www.evokehub.com
